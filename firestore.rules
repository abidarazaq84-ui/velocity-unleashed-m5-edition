rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Users ---
    function isValidUser(data) {
      return data.uid is string &&
             data.displayName is string &&
             data.displayName.size() <= 64 &&
             (data.currency == null || data.currency is int) &&
             (data.xp == null || data.xp is int) &&
             (data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 800000)) &&
             (data.stats == null || data.stats is map) &&
             (data.inventory == null || data.inventory is map);
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; 
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        // Action: Profile Update
        (incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'lastMatchId', 'dailyChallengeStatus', 'inventory'])) ||
        // Action: Stats Update (restricted)
        (incoming().diff(existing()).affectedKeys().hasOnly(['stats', 'xp', 'currency', 'rankPoints', 'rank']))
      );
    }

    // --- Leaderboards ---
    match /leaderboards/global/entries/{userId} {
      allow read: if isSignedIn();
      allow write: if false; // Should be updated by system after match
    }

    // --- Matches ---
    match /matches/{matchId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && resource.data.players.hasAny([request.auth.uid]);
      allow create: if isSignedIn(); // Allow match creation at the end of game
      allow update, delete: if false;
    }

    // --- Rooms ---
    match /rooms/{roomId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        // Allow updating own presence/position in room
        incoming().activePlayers.keys().hasAll(existing().activePlayers.keys())
      );
    }

    // --- Feedback ---
    function isValidFeedback(data) {
      return data.uid == request.auth.uid &&
             data.message is string &&
             data.message.size() <= 2000 &&
             data.timestamp == serverTimestamp();
    }

    match /feedback/{feedbackId} {
      allow create: if isSignedIn() && isValidFeedback(incoming());
      allow read, update, delete: if false; // Only admins should read/manage
    }
  }
}
